# Copy to `.env` locally. On Vercel: Project → Settings → Environment Variables (Production + Preview as needed).
# Vite only exposes variables prefixed with VITE_.

# Canonical site URL (no trailing slash). Used for sitemap, robots.txt, SEO JSON-LD, and canonicals at build time.
# On Vercel Production, set this to your real URL, e.g. https://your-app.vercel.app or your custom domain.
VITE_SITE_URL=https://example.com

# EmailJS (contact form). Required for production submissions.
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=

# After changing env on Vercel, trigger a new deployment so values are inlined into the client bundle.
# In EmailJS dashboard, allow your production (and preview) origins if you use origin restrictions.

# E2E: after `npm run build`, run `npx playwright install` once, then `npm run test:e2e` or `npm run test:e2e:ci`.
# On Windows, if Playwright hangs after tests, start preview in a second terminal:
#   npm run preview -- --host 127.0.0.1 --port 5199 --strictPort
# then set PLAYWRIGHT_SKIP_WEBSERVER=1 (PowerShell: $env:PLAYWRIGHT_SKIP_WEBSERVER='1') and run npm run test:e2e:ci.
